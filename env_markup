# Настройки параметров конфигурации нового установленного сервера Ubuntu24.04, Ubuntu26.04
# Скопируйте этот шаблон в новый файл ".env" в директории проекта и заполните файл актуальными значениями.
# Когда ".env" файл будет готов, запустите установщик: ./main.sh

# Имя нового пользователя
NEW_USER=""

# Название хоста или доменное имя сервера
HOST_LOCATION=""

# SSH ключ для входа на сервер без пароля с текущего компьютера, cat ~/.ssh/id_ed25519.pub
SSH_AUTH_KEY=""

# Список доверенных ip's для доступа через SSH через пробел: "ipv4 ipv4 ipv4".
# Если нужно оставить доступ с любого ip, оставьте значение: "*"
ALLOWED_HOSTS="*"
